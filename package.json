{
  "name": "triadmind-core",
  "version": "1.0.0",
  "bin": {
    "triadmind": "dist/cli.js"
  },
  "description": "TriadMind: topology-first AI software architecture CLI based on the vertex triad method.",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist",
    "README.md",
    "user guide.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "init": "tsx cli.ts init",
    "prompt": "tsx cli.ts prompt",
    "pipeline": "tsx cli.ts pipeline",
    "macro": "tsx cli.ts macro",
    "meso": "tsx cli.ts meso",
    "micro": "tsx cli.ts micro",
    "sync": "tsx cli.ts sync",
    "watch": "tsx cli.ts watch",
    "protocol": "tsx cli.ts protocol",
    "finalize": "tsx cli.ts finalize",
    "legacy": "tsx cli.ts legacy",
    "converge": "tsx cli.ts converge",
    "plan": "tsx cli.ts plan",
    "auto": "tsx cli.ts auto",
    "invoke": "tsx cli.ts invoke",
    "rules": "tsx cli.ts rules",
    "self": "tsx cli.ts self",
    "adapters": "tsx cli.ts adapters",
    "heal": "tsx cli.ts heal",
    "snapshots": "tsx cli.ts snapshots",
    "snapshot": "tsx cli.ts snapshot",
    "rollback": "tsx cli.ts rollback",
    "handoff": "tsx cli.ts handoff",
    "master": "tsx cli.ts master",
    "apply": "tsx cli.ts apply",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "keywords": [
    "ai",
    "architecture",
    "agent",
    "topology",
    "cli",
    "triadmind"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "type": "commonjs",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "inquirer": "^8.2.7",
    "tree-sitter": "^0.21.1",
    "tree-sitter-cpp": "^0.21.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^28.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.12",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
